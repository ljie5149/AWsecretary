@model AWsecretary.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "忘記密碼";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="ForgotPassword" method="post" class="mb-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-2">
        <label asp-for="Identifier" class="form-label"></label>
        <input asp-for="Identifier" class="form-control" />
        <span asp-validation-for="Identifier" class="text-danger"></span>
        <small class="form-text text-muted">請輸入會員帳號或電子郵件，我們會寄送重設密碼連結（目前為示範，請實作 Email 發送）。</small>
    </div>

    <button type="submit" class="btn btn-primary">送出</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}